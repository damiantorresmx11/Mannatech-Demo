# ── BigCommerce ─────────────────────────────────────────────────────────
BIGCOMMERCE_STORE_HASH=
BIGCOMMERCE_ACCESS_TOKEN=
BIGCOMMERCE_CHANNEL_ID=1
# Optional: Storefront API token (for client-side operations)
# BIGCOMMERCE_STOREFRONT_TOKEN=

# ── Auth.js ─────────────────────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=https://mannatech.dmlabs.mx
AUTH_TRUST_HOST=true

# ── CMS ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CMS_API_URL=https://api-cms.mannatech.dmlabs.mx

# ── Email (SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
INTERNAL_EMAIL_SECRET=

# ── Umami Analytics ─────────────────────────────────────────────────────
UMAMI_API_URL=http://127.0.0.1:8010
UMAMI_USERNAME=admin
UMAMI_PASSWORD=
UMAMI_WEBSITE_ID=

# ── Uptime Kuma ─────────────────────────────────────────────────────────
UPTIME_KUMA_URL=http://127.0.0.1:3001

# ── Chatwoot ────────────────────────────────────────────────────────────
CHATWOOT_API_URL=http://127.0.0.1:3006
CHATWOOT_ADMIN_EMAIL=admin@dmlabs.mx
CHATWOOT_ADMIN_PASSWORD=
CHATWOOT_ACCOUNT_ID=1
